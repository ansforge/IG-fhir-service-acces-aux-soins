         fhir:ElementDefinition.constraint.severity [ fhir:value "error" ] ;
         fhir:ElementDefinition.constraint.human [ fhir:value "Cancelation reason is only used for appointments that have been cancelled, or no-show" ] ;
         fhir:ElementDefinition.constraint.expression [ fhir:value "Appointment.cancelationReason.exists() implies (Appointment.status='no-show' or Appointment.status='cancelled')" ] ;
         fhir:ElementDefinition.constraint.xpath [ fhir:value "not(exists(f:cancellationReason)) or f:status/@value=('no-show', 'cancelled')" ] ;
         fhir:ElementDefinition.constraint.source [
